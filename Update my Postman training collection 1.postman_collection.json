        {
          "name": "Get Lists / read created lists",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "console.log(\"BEFORE\");\r",
                  "\r",
                  "pm.sendRequest({\r",
                  "    url: \"https://postman-echo.com/get\",\r",
                  "    method: \"GET\"\r",
                  "}, function (err, response) {\r",
                  "    if (err) {\r",
                  "        console.error(err);\r",
                  "    } else {\r",
                  "        console.log(response.json());\r",
                  "    }\r",
                  "});\r",
                  "``\r",
                  ""
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "",
                  "const response = pm.response.json();",
                  "",
                  "const listId1 = pm.collectionVariables.get(\"listId1\");",
                  "const listId2 = pm.collectionVariables.get(\"listId2\");",
                  "",
                  "pm.test(\"List 1 exists\", () => {",
                  "    const list = response.lists.find(l => l.id == listId1);",
                  "    pm.expect(list).to.not.be.undefined;",
                  "});",
                  "",
                  "pm.test(\"List 2 exists\", () => {",
                  "    const list = response.lists.find(l => l.id == listId2);",
                  "    pm.expect(list).to.not.be.undefined;",
                  "});",
                  ""
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
